<?xml version="1.0" encoding="UTF-8"?>
<list xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../xsd/skills.xsd">
	<skill id="9000" levels="3" name="Spirit of Meraki">
		<!-- Passive VIP Skill: Enhanced rates and stats. -->
		<table name="#rExp">1.2 1.5 2.0</table>
		<table name="#spd">1.05 1.10 1.15</table>
		<table name="#weight">1.0 1.5 2.0</table>
		<icon>icon.skill1323</icon>
		<operateType>P</operateType>
		<targetType>SELF</targetType>
		<magicLevel>1</magicLevel>
		<effects>
			<effect name="Buff">
				<!-- Rates -->
				<mul stat="rExp">#rExp</mul>
				
				<!-- Combat Stats -->
				<mul stat="pAtk">#spd</mul>
				<mul stat="mAtk">#spd</mul>
				<mul stat="pDef">#spd</mul>
				<mul stat="mDef">#spd</mul>
				<mul stat="pAtkSpd">#spd</mul>
				<mul stat="mAtkSpd">#spd</mul>
				<mul stat="runSpd">#spd</mul>
				
				<!-- Vitality Stats -->
				<mul stat="maxHp">#spd</mul>
				<mul stat="maxMp">#spd</mul>
				<mul stat="maxCp">#spd</mul>
				<mul stat="weightLimit">#weight</mul>
			</effect>
		</effects>
	</skill>
</list>
