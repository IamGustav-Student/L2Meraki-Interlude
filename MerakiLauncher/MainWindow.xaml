<Window x:Class="MerakiLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Meraki Launcher" Height="450" Width="800"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen">
    <Border CornerRadius="15" Background="#1A1A1A" BorderBrush="#00FFFF" BorderThickness="1">
        <Grid>
            <!-- Background Image Placeholder (Can be changed by user) -->
            <Image Source="https://raw.githubusercontent.com/iamgu/L2Meraki-Interlude/main/launcher/bg.png" Stretch="UniformToFill" Opacity="0.4" />
            
            <!-- Header -->
            <StackPanel Margin="20">
                <TextBlock Text="L2 MERAKI" Foreground="#00FFFF" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center">
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="10" Color="#00FFFF" ShadowDepth="0" />
                    </TextBlock.Effect>
                </TextBlock>
                <TextBlock Text="PREMIUM INTERLUDE EXPERIENCE" Foreground="White" FontSize="12" HorizontalAlignment="Center" Opacity="0.7" />
            </StackPanel>

            <!-- Bottom Controls -->
            <StackPanel VerticalAlignment="Bottom" Margin="40">
                <TextBlock x:Name="StatusLabel" Text="Checking for updates..." Foreground="White" FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,10" />
                
                <ProgressBar x:Name="UpdateProgress" Height="10" Width="600" Background="#333" Foreground="#00FFFF" BorderThickness="0" Margin="0,0,0,20" />
                
                <Button x:Name="StartBtn" Content="START GAME" Width="200" Height="50" 
                        Background="#00FFFF" Foreground="Black" FontSize="18" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand" Click="StartBtn_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="25" />
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>

            <!-- Close Button -->
            <Button Content="X" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="20" Background="Transparent" BorderThickness="0" Foreground="White" FontSize="16" Click="CloseBtn_Click" />
        </Grid>
    </Border>
</Window>
